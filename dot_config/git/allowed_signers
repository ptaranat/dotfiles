# Maps identities to the SSH keys allowed to sign for them, so `git log
# --show-signature` and `git verify-commit` can validate locally. Without it
# git reports "No principal matched" even for signatures it created itself.
#
# Format: <identity> namespaces="git" <key type> <key>
# Public keys only; nothing here is secret.
panat.taranat@gmail.com namespaces="git" ssh-rsa 
