theme = srcery

# No font-family was set here, so ghostty fell back to a system font with no
# Nerd Font glyphs: powerline separators, git branch icons and eza's file
# icons all rendered as tofu. MesloLGS is already installed (it is the font
# p10k shipped with) and alacritty was already pointing at it.
font-family = "MesloLGS Nerd Font"
font-size = 13

cursor-style = block
cursor-style-blink = true

# Ghostty's shell integration sets a blinking bar (\e[5 q) at every prompt,
# which overrides cursor-style. Turn that off so the block sticks.
shell-integration-features = no-cursor

custom-shader = shaders/cursor_warp.glsl

keybind = global:cmd+grave_accent=toggle_quick_terminal
