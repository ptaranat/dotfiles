#!/bin/sh
# Install apt packages on the Linux box. The macOS counterpart is
# 10-packages.sh, which reads the Brewfile; .chezmoiignore gates each script to
# its own OS so only one of the pair ever runs.
#
# The hash below is what makes run_onchange_ work. chezmoi re-runs this script
# when its *rendered content* changes, and the script text itself almost never
# changes -- so without embedding a hash of the package list, editing
# .chezmoidata.yaml would trigger nothing at all.
#
# packages hash: {{ list .packages.apt.core .packages.apt.tools | toJson | sha256sum }}

set -eu

[ "$(uname -s)" = "Linux" ] || exit 0
command -v apt-get >/dev/null 2>&1 || {
	echo "==> apt-get not found; skipping package install"
	exit 0
}

echo "==> installing apt packages"

# --no-upgrade is deliberate and load-bearing.
#
# `apt-get install` on a package that is already installed will upgrade it if a
# newer candidate exists, so the plain form is not the safe operation its name
# suggests. Measured on this box, the plain form wanted to upgrade curl and its
# whole libcurl stack out of trixie-backports -- 10 packages nobody asked for,
# as a side effect of syncing dotfiles.
#
# That is the same mistake `brew bundle`'s default made on the macOS box, where
# it replaced the tmux binary underneath a running server and left the sessions
# listable but unattachable. --no-upgrade is the apt spelling of the
# --no-upgrade already passed to brew bundle in 10-packages.sh.
#
# To upgrade, run it by hand once you have checked what is running:
#     sudo apt-get update && sudo apt-get upgrade
sudo apt-get update -qq
sudo apt-get install -y --no-upgrade --no-install-recommends \
	{{ concat .packages.apt.core .packages.apt.tools | sortAlpha | join " \\\n\t" }}

# Debian ships two of these under names that collide with older packages, so
# the binaries are fdfind and batcat rather than fd and bat. The zsh config
# calls them by their upstream names. ~/.local/bin is prepended in .zshenv.
#
# These are no-ops on a box where linuxbrew still provides fd and bat, since
# linuxbrew sits ahead of ~/.local/bin on PATH. They matter on a fresh machine.
mkdir -p "$HOME/.local/bin"
for pair in fdfind:fd batcat:bat; do
	src="${pair%%:*}"
	dst="${pair##*:}"
	if command -v "$src" >/dev/null 2>&1 && ! command -v "$dst" >/dev/null 2>&1; then
		ln -sf "$(command -v "$src")" "$HOME/.local/bin/$dst"
	fi
done

echo "==> apt packages up to date (nothing upgraded)"

# TODO: the tools in packages.brew.linux (neovim, gh) and the installer-based
# ones (mise, sesh) are still installed by hand. Automating them is the next
# step; doing it needs a decision about whether this box keeps linuxbrew at all.
