#!/bin/sh
# Install everything in the Brewfile.
#
# Runs before the other numbered scripts so tools exist before anything tries
# to use them (30-completions needs pnpm present to generate its completions).
#
# The hash below is what makes run_onchange_ work here. chezmoi re-runs this
# script when its *rendered content* changes, and the script itself rarely
# changes -- so without embedding a hash of the Brewfile, editing the Brewfile
# would never trigger a reinstall.
#
# Brewfile hash: {{ include "Brewfile" | sha256sum }}

set -eu

[ "$(uname -s)" = "Darwin" ] || exit 0
command -v brew >/dev/null 2>&1 || {
	echo "==> brew not installed; skipping package install"
	exit 0
}

BREWFILE="{{ .chezmoi.sourceDir }}/Brewfile"
[ -f "$BREWFILE" ] || exit 0

echo "==> installing packages from Brewfile"

# --no-upgrade is deliberate and important.
#
# `brew bundle` installs *and upgrades* by default. That is how a routine
# apply replaced the tmux binary underneath a running server: the sessions
# stayed listable but could not be attached, and `brew cleanup` then removed
# the old binary so there was no way back. Upgrading is a decision to make
# deliberately, when nothing important is mid-flight -- not a side effect of
# syncing dotfiles.
#
# To upgrade, run it by hand and check what is running first:
#     brew bundle --file="$(chezmoi source-path)/Brewfile"
brew bundle --file="$BREWFILE" --no-upgrade

echo "==> packages up to date (nothing upgraded; run brew bundle by hand for that)"
